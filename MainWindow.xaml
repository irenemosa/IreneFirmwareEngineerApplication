<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IreneFirmwareEngineerApplication"
        mc:Ignorable="d"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Title="Firmware Engineer Application - Irene Mollet Sala" Height="700" Width="1200">
    <Grid Margin="0,-4,0,4">

        <!-- Grid config -->
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->

        <TextBlock Text="Firmware Engineer Application" Grid.Column="0" HorizontalAlignment="Left"  Margin="10,0,0,0" VerticalAlignment="Center"/>
        <TextBlock Text="Irene Mollet Sala" Grid.Row="1"  HorizontalAlignment="Left" Height="17" Margin="30,10,0,0" VerticalAlignment="Top" Width="90"/>

        <TextBlock Grid.Row="1"
           Grid.ColumnSpan="2"
           Margin="30,25,0,0">

    <Hyperlink NavigateUri="https://www.linkedin.com/in/irenemollet/"
               RequestNavigate="Hyperlink_RequestNavigate">
        Visit my LinkedIn!
    </Hyperlink>

        </TextBlock>

        <!-- Information -->
        <WrapPanel Grid.Row="1"
           Margin="20,70,20,20">

            <Button Content="About me" Width="120" Height="60" Margin="5" Click="Open_PInfo"/>
            <Button Content="Education" Width="120" Height="60" Margin="5" Click="Open_Education"/>
            <Button Content="Thesis" Width="120" Height="60" Margin="5" Click="Open_Thesis"/>
            <Button Content="Why do I want to &#xD;&#xA;work at Fliteboard" Width="120" Height="60" Margin="5" Click="Open_Why"/>
            <Button Content="Projects" Width="120" Height="60" Margin="5" Click="Open_WorkExperience"/> 
            <Button Content="What can I bring &#xD;&#xA;to Fliteboard" Width="120" Height="60" Margin="5" Click="Open_WhatIBring "/>

        </WrapPanel>
        <!-- Experience -->
        <TextBlock Text="Experience" Grid.Column="1"  HorizontalAlignment="Left" Margin="34,18,0,0" VerticalAlignment="Top" Grid.Row="1"/>

        <ComboBox Grid.Column="1" x:Name="ComboBox_experience" Margin="20,40,20,0" HorizontalAlignment="Stretch" Height="26" VerticalAlignment="Top" SelectionChanged="ComboBox_SelectionChanged" Grid.Row="1">
            <ComboBoxItem Content="Firmware Design and Development"/>
            <ComboBoxItem Content="Embedded Solutions Testing and Validation"/>
            <ComboBoxItem Content="Final Product Validation - EV Charger"/>
            <ComboBoxItem Content="Software Debugging"/>
            <ComboBoxItem Content="Hardware Debugging and Diagnostics - Altium"/>

            <ComboBoxItem Content="Programming Languages"/>

            <ComboBoxItem Content="Hardware and Software Migration"/>

            <ComboBoxItem Content="Microcontrollers and Embedded Interfaces"/>
            <ComboBoxItem Content="Documentation"/>
            <ComboBoxItem Content="Version Control and Collaboration"/>

        </ComboBox>

        <!-- Demos -->
        <ListView  x:Name="lstDemoOutput" HorizontalAlignment="Stretch" Grid.Row="1" Grid.Column="1" Margin="20,74,20,20" VerticalAlignment="Top" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" >
                        <StackPanel>

                            <TextBlock Text="{Binding Title}"
                               FontWeight="Bold"
                               FontSize="16"/>

                            <ListBox ItemsSource="{Binding Experiences}"
                                HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat=- {0}}"
                                            TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>

                            </ListBox>

                            <Image Source="{Binding ImagePath}"
                                MaxHeight="400"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>



    </Grid>
</Window>
