        mc:Ignorable="d"
        Title="Education" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

            
        <!-- Bacheloor degree -->
        <TextBox Grid.Column="0" Text="Bachelor's degree in ICT Systems Engineering - EPSEM (Barcelona, Spain)" HorizontalAlignment="Left" Margin="56,26,0,0" VerticalAlignment="Top"/>
        <StackPanel Grid.Column="0" Margin="60,44,0,0">

            <TextBlock Margin="0,0,0,10">
        <Hyperlink NavigateUri="https://www.upc.edu/en/bachelors/ict-systems-engineering-manresa-epsem"
