        </StackPanel>

        <Image Margin="491,199,17,38" Source="/Images/Image2.png" Stretch="Fill"/>
        <Image Margin="596,70,26,253" Source="/Images/Image3.png" Stretch="Fill"/>
        <TextBlock HorizontalAlignment="Left" Height="241" Margin="62,105,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="242"><Run Text="I designed and developed an automated testing and validation system for embedded electronic devices. The solution combined custom hardware and software to automatically diagnose electronic boards, verify firmware functionality, and validate communication interfaces."/><LineBreak/><Run/><LineBreak/><Run Text="The system was capable of testing digital and analog signals, as well as communication protocols such as Bluetooth, RFID, Wi-Fi, RS-232, RS-485, USB, and CAN. It significantly reduced the need for manual testing by automating validation procedures and generating reliable test results."/><Run Text=" The results where stored into a database and could be viewed and analyzed through website"/><Run Language="ca-es" Text="."/></TextBlock>
        <TextBox HorizontalAlignment="Left" Height="51" Margin="136,346,0,0" TextWrapping="Wrap" Text="The thesis was awarded first place for Best Bachelor's Thesis in ICT Systems Engineering in my region." VerticalAlignment="Top" Width="201"/>
        <TextBlock HorizontalAlignment="Left" Height="27" Margin="62,31,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="360" Text="Automated Validation Platform for Embedded Electronic Systems"/>
        <Image Margin="314,70,309,118" Source="/Images/Image9.png" Stretch="Fill"/>


    </Grid>
