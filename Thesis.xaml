        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IreneFirmwareEngineerApplication"
        mc:Ignorable="d"
        Title="Thesis" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="62,58,0,0">
            <TextBlock><Hyperlink NavigateUri="https://youtu.be/55Py0ZfdEn8"
                   RequestNavigate="Hyperlink_RequestNavigate"><Run Text="Video Demonstration Thesis"/></Hyperlink></TextBlock>
            <TextBlock><Hyperlink NavigateUri="https://upcommons.upc.edu/server/api/core/bitstreams/e80526f2-edbd-4b04-aecd-3f59c19d57a5/content"
